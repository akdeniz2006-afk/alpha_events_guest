rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /event_speakers/{speakerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /speaker_questions/{questionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }



    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /*
      ADMINS
      Admin kullan?c?lar? sadece admin okuyabilir.
      Admin olu?turma/silme rules ?zerinden kapal?.
    */
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    /*
      GUEST APP LOGIN / PARTICIPANTS

      Guest App login ekran?, kullan?c? Firebase Auth ile giri? yapmadan
      event_guests i?inde whatsappNumber + code ar?yor.
      Bu nedenle read a??k olmal?.
      Yazma sadece admin.
    */
    match /event_guests/{guestId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      ROOMS
      Guest App oda bilgisini okuyabilir.
      Yazma sadece admin.
    */
    match /event_rooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      TRANSPORT
      Guest App transfer bilgisini okuyabilir.
      Yazma sadece admin.
    */
    match /event_transport/{transportId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /event_transports/{transportId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      PROGRAM
      Guest App program bilgisini okuyabilir.
      Yazma sadece admin.
    */
    match /event_program/{programId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      ANNOUNCEMENTS
      Guest App duyurular? okuyabilir.
      Yazma sadece admin.
    */
    match /event_announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      ACTIVITIES
      Guest App aktiviteleri okuyabilir.
      Yazma sadece admin.
    */
    match /event_activities/{activityId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      ACTIVITY RESPONSES
      Kat?l?mc? aktivite cevab? olu?turabilir.
      Admin okuyabilir/g?ncelleyebilir/silebilir.
    */


    match /event_gift_deliveries/{deliveryId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /event_checkins/{checkinId} {
      allow read, create, update, delete: if isAdmin();
    }
    match /event_activity_responses/{responseId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    /*
      PHOTOS
      Guest App foto?raflar? okuyabilir.
      Yazma sadece admin.
    */
    match /event_photos/{photoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      VIDEOS
      Guest App videolar? okuyabilir.
      Yazma sadece admin.
    */
    match /event_videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      FEEDBACK / EVALUATION
      Kat?l?mc? de?erlendirme g?nderebilir.
      Admin okuyabilir/g?ncelleyebilir/silebilir.
    */
    match /event_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /event_evaluations/{evaluationId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    /*
      SETTINGS
      Guest App ayarlar? okuyabilir.
      Yazma sadece admin.
    */
    match /event_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      MANAGED MESSAGES
      ?imdilik admin eri?imi.
    */
    match /managed_messages/{messageId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      WHATSAPP - ?LER? FAZ
      ?imdilik admin eri?imi.
    */
    match /whatsapp_messages/{messageId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      LEGACY / ESK? KOLEKS?YON ?S?MLER?
      Eski ekranlar k?r?lmas?n diye admin eri?imi korunuyor.
    */
    match /participants/{participantId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /program/{programId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /transport/{transportId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      GUEST PUBLIC
    */
    match /guest_public/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /*
      DEFAULT DENY
    */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
