rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /*
      ADMIN USERS

      Firestore yapısı:

      admins
        └── FIREBASE_AUTH_UID
              name: "Hüseyin"
              email: "admin@alphaevents.com.tr"
              role: "admin"
              active: true
    */
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    /*
      PARTICIPANTS / GUESTS

      Admin panelde katılımcılar ekranı:
      collection('event_guests')
    */
    match /event_guests/{guestId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      ROOMS

      Admin panelde oda yönetimi:
      collection('event_rooms')
    */
    match /event_rooms/{roomId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      TRANSPORT / ULAŞIM

      Bazı dosyalarda tekil, bazı dosyalarda çoğul kullanım olabilir.
      Bu yüzden ikisini de güvenli şekilde açıyoruz.
    */
    match /event_transport/{transportId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /event_transports/{transportId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      PROGRAM

      Admin panel program ekranı:
      collection('event_program')
    */
    match /event_program/{programId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      ANNOUNCEMENTS / DUYURULAR

      Admin panel duyurular ekranı:
      collection('event_announcements')
    */
    match /event_announcements/{announcementId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      ACTIVITIES / AKTİVİTELER

      Admin panel aktiviteler ekranı:
      collection('event_activities')
    */
    match /event_activities/{activityId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      PHOTOS

      Admin panel fotoğraf ekranı:
      collection('event_photos')
    */
    match /event_photos/{photoId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      VIDEOS

      Admin panel video ekranı:
      collection('event_videos')
    */
    match /event_videos/{videoId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      FEEDBACK / EVALUATION

      Admin panel değerlendirme / geri bildirim ekranı.
      İki isim ihtimalini de açık bırakıyoruz.
    */
    match /event_feedback/{feedbackId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /event_evaluations/{evaluationId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      SETTINGS

      Guest app ayarları:
      collection('event_settings')
    */
    match /event_settings/{settingId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      MANAGED MESSAGES

      Admin panelden yönetilen mesajlar.
    */
    match /managed_messages/{messageId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      WHATSAPP - İLERİ FAZ

      WhatsApp entegrasyonu şimdilik admin erişimine açık.
    */
    match /whatsapp_messages/{messageId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      LEGACY / ESKİ KOLEKSİYON İSİMLERİ

      Daha önce bazı dosyalarda bu isimler kullanılmış olabilir.
      Admin panelin eski ekranları kırılmasın diye admin erişimine açık.
    */
    match /participants/{participantId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /program/{programId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /transport/{transportId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read, create, update, delete: if isAdmin();
    }

    /*
      GUEST APP OKUMA İHTİMALİ

      Guest app giriş yapan kullanıcıya genel etkinlik içeriklerini okuyabilsin diye
      public olmayan ama signed-in kullanıcıya açık okuma alanları.
      Şimdilik yazma sadece admin.
    */
    match /guest_public/{documentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /*
      DEFAULT DENY

      Yukarıda açıkça izin vermediğimiz hiçbir koleksiyon okunamaz/yazılamaz.
    */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}